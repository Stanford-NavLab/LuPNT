# Get LuPNT data
curl -L https://bit.ly/LuPNT_data -o LuPNT_data.zip
unzip LuPNT_data.zip
rm LuPNT_data.zip

# Set the environment variable
echo "export LUPNT_DATA_PATH=$(pwd)/LuPNT_data" >> ~/.bashrc
source ~/.bashrc

# Install LuPNT
sudo apt-get update
sudo apt-get install -y cmake libomp-dev
pip install .

cd examples/python/notebooks
