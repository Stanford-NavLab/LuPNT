# Get LuPNT data
curl -L https://bit.ly/LuPNT_data -o LuPNT_data.zip
unzip LuPNT_data.zip
rm LuPNT_data.zip

# Set the environment variable
echo "export LUPNT_DATA_PATH=$(pwd)/LuPNT_data" >> ~/.bashrc
source ~/.bashrc

# Increase swap space
sudo swapoff -a
sudo dd if=/dev/zero of=/swapfile bs=1G count=16
sudo mkswap /swapfile
sudo swapon /swapfile

# Set MAKEFLAGS environment variable
export MAKEFLAGS=-j1

# Install LuPNT
sudo apt-get update
sudo apt-get install -y cmake libomp-dev
pip install . -v

cd examples/python/notebooks
