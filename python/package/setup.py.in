from distutils.core import setup

setup(
    name='lupnt',
    version='${PROJECT_VERSION}',
    description='The Python interface of the lupnt library.',
    author='Stanford Navigation and Autonomous Vehicles (NAV) Lab',
    author_email='allan.leal@erdw.ethz.ch',
    url='lupnt.github.io',
    license='MIT',
    packages=['lupnt', 'lupnt.extensions'],
    package_data={
        'lupnt': [
            'pylupnt${PYTHON_MODULE_EXTENSION}',
            'pylupnt/*'
            '*.pyi',
        ],
    }
)
